# ─── 資料庫 ──────────────────────────────────────────────────────────────────
DB_NAME=secvulndb
DB_USER=secvulnv2
DB_PASSWORD=changeme

# ─── JWT（請務必更換為長隨機字串）──────────────────────────────────────────────
# 建議產生方式：openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# ─── 前端存取埠號（預設 8443，HTTPS）────────────────────────────────────────
FRONTEND_PORT=8443

# ─── CORS（前端對外 URL，需含 https 與埠號）──────────────────────────────────
# 若伺服器有固定 IP 或域名，請改為對應位址，例如：
# CORS_ORIGIN=https://192.168.1.100:8443
CORS_ORIGIN=https://localhost:8443
